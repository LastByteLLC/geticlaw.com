---
import Layout from '../components/layout/Layout.astro';
import CtaSection from '../components/home/CtaSection.astro';
import ShowcaseRow from '../components/ShowcaseRow.astro';
import { copy } from '../content/copy';
---

<Layout title={copy.features.headline}>
  <main>
    <section class="container page-header">
      <h1 class="page-title">{copy.features.headline}</h1>
      <p class="page-subtitle">{copy.features.subheadline}</p>

      <div class="features-screenshot">
        <img
          src="/screenshots/iClaw-Podcast-Screenrecord.gif"
          alt="iClaw podcast feature demo"
          class="screenshot-img"
          draggable="false"
        />
      </div>

      <div class="pillars-grid">
        {copy.features.pillars.map((pillar) => (
          <div class="pillar-card">
            <h2 class="pillar-title">{pillar.title}</h2>
            <p class="pillar-description">{pillar.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="showcase container">
      {copy.features.showcase.map((row) => (
        <ShowcaseRow {...row} />
      ))}
    </section>

    <CtaSection />
  </main>
</Layout>

<style>
  .page-header {
    padding: 64px 24px 24px;
  }

  .page-title {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .page-subtitle {
    font-size: 18px;
    color: var(--color-text-secondary);
    margin-bottom: 48px;
  }

  .features-screenshot {
    text-align: center;
    margin-bottom: 64px;
  }

  .screenshot-img {
    max-width: 100%;
    width: 520px;
    border-radius: var(--radius-lg);
    margin: 0 auto;
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
  }

  .pillar-card {
    padding: 28px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    transition: border-color 0.15s;
  }

  .pillar-card:hover {
    border-color: var(--color-text-secondary);
  }

  .pillar-title {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .pillar-description {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* Showcase wrapper — individual row layout lives in ShowcaseRow.astro */
  .showcase {
    padding: 64px 24px 80px;
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  @media (max-width: 768px) {
    .showcase {
      gap: 56px;
    }
  }
</style>

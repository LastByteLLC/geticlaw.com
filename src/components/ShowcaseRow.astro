---
interface Props {
  title: string;
  description: string;
  imgSrc: string;
  imgAlt: string;
  imgWidth: number;
  imgHeight: number;
  imgMaxWidth: number;
  reverse?: boolean;
}

const {
  title,
  description,
  imgSrc,
  imgAlt,
  imgWidth,
  imgHeight,
  imgMaxWidth,
  reverse = false,
} = Astro.props;
---

<div class:list={['showcase-row', { 'showcase-row-reverse': reverse }]}>
  <div class="showcase-img">
    <img
      src={imgSrc}
      alt={imgAlt}
      width={imgWidth}
      height={imgHeight}
      draggable="false"
      style={`max-width: min(100%, ${imgMaxWidth}px);`}
    />
  </div>
  <div class="showcase-text">
    <h3 class="showcase-title">{title}</h3>
    <p class="showcase-description">{description}</p>
  </div>
</div>

<style>
  .showcase-row {
    display: flex;
    align-items: center;
    gap: 48px;
  }

  .showcase-row-reverse {
    flex-direction: row-reverse;
  }

  .showcase-img {
    flex: 1 1 50%;
    display: flex;
    justify-content: center;
  }

  .showcase-img img {
    height: auto;
    border-radius: var(--radius-lg);
  }

  .showcase-text {
    flex: 1 1 50%;
  }

  .showcase-title {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .showcase-description {
    font-size: clamp(15px, 2vw, 17px);
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 440px;
  }

  @media (max-width: 768px) {
    .showcase-row,
    .showcase-row-reverse {
      flex-direction: column;
      text-align: center;
    }

    .showcase-description {
      max-width: none;
    }
  }
</style>

---
interface Props {
  text: string;
  role: 'assistant' | 'user';
}

const { text, role } = Astro.props;
---

<div class:list={['chat-bubble', `chat-${role}`]}>
  <p>{text}</p>
</div>

<style>
  .chat-bubble {
    padding: 10px 14px;
    border-radius: 14px;
    font-size: 14px;
    line-height: 1.45;
    max-width: 85%;
  }

  .chat-assistant {
    background: var(--bubble-bg);
    color: var(--bubble-text);
    border-bottom-left-radius: 4px;
  }

  .chat-user {
    background: var(--color-accent);
    color: #ffffff;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }
</style>

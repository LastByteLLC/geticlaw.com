---
import { copy } from '../../content/copy';
---

<header class="menubar" role="banner">
  <div class="menubar-left">
    <span class="menubar-apple" aria-hidden="true">&#63743;</span>
    {copy.home.menubar.appMenuItems.map((item) => (
      <span class="menubar-item">{item}</span>
    ))}
  </div>
  <div class="menubar-right">
    <button
      class="menubar-icon-btn"
      id="menubar-toggle"
      aria-label="Open iClaw"
      aria-expanded="false"
      aria-controls="chat-overlay"
    >
      <svg class="menubar-icon" viewBox="0 0 746 746" aria-hidden="true">
        <path fill="currentColor" d="M200 712h-84q-27 0-40-26-3-7-3-15v-84q1-28 26-38l35-11q4-1 6 2 23 31 60 36l8 1-27-19q-33-26-41-68-5-36 9-69 8-22 22-40l76-121q31-50 64-99A308 308 0 0 1 491 45q71-14 137 16 8 3 12 8c9 8 7 20-3 26l-11 5q-23 9-30 33l-4 13q-9 26-36 33l-17 6q-10 3-11 14c-2 11-3 22-11 31q-8 7-18 12l-6 4q-15 6-17 23-6 46-16 91-4 22 11 40 12 11 26 20 12 7 16 20 4 20-9 33l-49 46q-31 29-69 51-33 21-71 28-20 4-41 1-4-1-6 4l-28 78q-10 28-40 31"/>
        <path fill="currentColor" d="M615 347q-31 35-63 67-8 8-20 14-2 3-4-1-11-18-30-29-8-4-15-13-8-14-4-29l12-59q0-3 3-5 16-15 37-15 9 0 14-7c15-22 36-37 56-53q27-20 46-46 10-15 17-31l3-6c3-5 10-4 13 1q6 13 7 28c5 44-8 84-30 123q-18 31-42 61"/>
      </svg>
    </button>
    <span class="menubar-status" aria-hidden="true">
      <svg class="menubar-status-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 12.55a11 11 0 0 1 14.08 0" /><path d="M1.42 9a16 16 0 0 1 21.16 0" /><path d="M8.53 16.11a6 6 0 0 1 6.95 0" /><circle cx="12" cy="20" r="1" fill="currentColor" stroke="none" />
      </svg>
      <svg class="menubar-status-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="1" y="6" width="18" height="12" rx="2" /><line x1="23" y1="13" x2="23" y2="11" />
      </svg>
    </span>
    <time class="menubar-clock" id="menubar-clock"></time>
  </div>
</header>

<style>
  .menubar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 12px;
    font-size: 13px;
    font-weight: 500;
    font-family: var(--font-system);
    background: var(--menubar-bg);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 0.5px solid var(--menubar-border);
    color: var(--menubar-text);
    user-select: none;
  }

  .menubar-left,
  .menubar-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .menubar-right {
    gap: 10px;
  }

  .menubar-apple {
    font-size: 15px;
    font-weight: 700;
  }

  .menubar-item {
    font-size: 13px;
    opacity: 0.85;
  }

  .menubar-status {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .menubar-status-icon {
    width: 14px;
    height: 14px;
    opacity: 0.7;
  }

  .menubar-clock {
    font-size: 13px;
    font-variant-numeric: tabular-nums;
    opacity: 0.85;
    min-width: 48px;
    text-align: right;
  }

  .menubar-icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 2px 4px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    color: var(--menubar-text);
    transition: background 0.15s;
    min-width: 44px;
    min-height: 28px;
    justify-content: center;
  }

  .menubar-icon-btn:hover {
    background: var(--menubar-hover);
  }

  .menubar-icon-btn[aria-expanded='true'] {
    background: var(--menubar-hover);
  }

  .menubar-icon {
    width: 18px;
    height: 18px;
  }

  @media (max-width: 768px) {
    .menubar-item,
    .menubar-status,
    .menubar-clock {
      display: none;
    }
  }
</style>

<script>
  function updateClock() {
    const el = document.getElementById('menubar-clock');
    if (!el) return;
    const now = new Date();
    el.textContent = now.toLocaleTimeString([], {
      hour: 'numeric',
      minute: '2-digit',
    });
  }
  updateClock();
  setInterval(updateClock, 30_000);
</script>

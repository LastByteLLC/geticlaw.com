---
import { copy, config } from '../../content/copy';
---

<section class="hero">
  <div class="hero-inner container">
    <h1 class="hero-headline">{copy.home.hero.headline}</h1>
    <p class="hero-subheadline">{copy.home.hero.subheadline}</p>
    <div class="hero-screenshot">
      <img src="/screenshots/iClaw-London-Screenrecord.gif" alt="iClaw app demo" class="screenshot-img" draggable="false" loading="lazy" />
    </div>
    <a href={config.dmgUrl} class="hero-download">
      <svg class="dmg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
      Download DMG
    </a>
  </div>
</section>

<style>
  .hero {
    padding: 80px 0 60px;
    text-align: center;
  }

  .hero-headline {
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .hero-subheadline {
    font-size: clamp(17px, 2.5vw, 21px);
    color: var(--color-text-secondary);
    max-width: 520px;
    margin: 0 auto 48px;
    line-height: 1.4;
  }

  .hero-screenshot {
    max-width: 800px;
    margin: 0 auto;
  }

  .screenshot-img {
    max-width: 100%;
    width: 520px;
    margin: 0 auto;
    border: none;
    border-radius: var(--radius-lg);
  }

  .hero-download {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 32px;
    padding: 14px 28px;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    background: var(--color-accent);
    color: #ffffff;
    transition: background 0.15s, transform 0.15s;
  }

  .hero-download:hover {
    background: var(--color-accent-hover);
    color: #ffffff;
  }

  .hero-download:active {
    transform: scale(0.97);
  }

  .dmg-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }
</style>

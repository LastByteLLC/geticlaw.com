---
import { copy } from '../../content/copy';
---

<section class="hero">
  <div class="hero-inner container">
    <h1 class="hero-headline">{copy.home.hero.headline}</h1>
    <p class="hero-subheadline">{copy.home.hero.subheadline}</p>
    <div class="hero-screenshot">
      <img src="/screenshots/iClaw-London-Screenrecord.gif" alt="iClaw app demo" class="screenshot-img" draggable="false" loading="lazy" />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 80px 0 60px;
    text-align: center;
  }

  .hero-headline {
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .hero-subheadline {
    font-size: clamp(17px, 2.5vw, 21px);
    color: var(--color-text-secondary);
    max-width: 520px;
    margin: 0 auto 48px;
    line-height: 1.4;
  }

  .hero-screenshot {
    max-width: 800px;
    margin: 0 auto;
  }

  .screenshot-img {
    max-width: 100%;
    width: 520px;
    margin: 0 auto;
    border: none;
    border-radius: var(--radius-lg);
  }
</style>

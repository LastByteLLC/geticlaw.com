---
import { copy } from '../../content/copy';
import { config } from '../../content/copy';
import ChatBubble from './ChatBubble.astro';
---

<div class="chat-overlay" id="chat-overlay" aria-hidden="true">
  <div class="chat-popup" id="chat-popup" role="dialog" aria-label="iClaw assistant">
    <div class="chat-messages">
      {copy.home.chat.messages.map((msg) => (
        <ChatBubble text={msg.text} role={msg.role} />
      ))}
    </div>
    <div class="chat-suggestions">
      {copy.home.chat.suggestions.map((s) => {
        const isDmg = s.label === 'Download DMG';
        const isAppStore = s.label === 'Get on the App Store';
        return (
          <a href={s.href} class:list={['chat-suggestion-pill', { 'cta-btn-primary': isDmg }]} {...(isAppStore ? { 'data-coming-soon': '' } : {})}>
            {isAppStore ? (
              <svg class="pill-icon-svg" viewBox="0 0 384 512" aria-hidden="true"><path fill="currentColor" d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/></svg>
            ) : isDmg ? (
              <svg class="pill-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
            ) : (
              <span class="pill-icon" aria-hidden="true">{s.icon}</span>
            )}
            {s.label}
          </a>
        );
      })}
    </div>
  </div>
</div>

<style>
  .chat-overlay {
    position: fixed;
    inset: 0;
    z-index: 999;
    display: flex;
    justify-content: flex-end;
    align-items: flex-start;
    padding-top: 36px;
    padding-right: 12px;
    background: transparent;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .chat-overlay.is-open {
    pointer-events: auto;
    opacity: 1;
  }

  .chat-popup {
    width: 320px;
    max-width: calc(100vw - 24px);
    padding: 16px;
    border-radius: 16px;
    background: linear-gradient(
      135deg,
      var(--glass-bg-gradient-start) 0%,
      var(--glass-bg-gradient-end) 100%
    );
    backdrop-filter: saturate(180%) blur(var(--glass-blur));
    -webkit-backdrop-filter: saturate(180%) blur(var(--glass-blur));
    border: 0.5px solid var(--glass-border);
    box-shadow:
      inset 0 0.5px 0 var(--glass-highlight),
      inset 0 -0.5px 0 rgba(0, 0, 0, 0.05),
      0 8px 32px var(--glass-shadow),
      0 2px 8px rgba(0, 0, 0, 0.06);
    transform: translateY(-12px) scale(0.96);
    transform-origin: top right;
    transition:
      transform 0.25s cubic-bezier(0.32, 0.72, 0, 1),
      opacity 0.2s ease;
    opacity: 0;
    will-change: transform;
  }

  .chat-overlay.is-open .chat-popup {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  .chat-messages {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 14px;
  }

  .chat-suggestions {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .chat-suggestion-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-radius: 12px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    color: var(--pill-text);
    background: var(--pill-bg);
    border: 0.5px solid var(--pill-border);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition:
      background 0.15s,
      transform 0.15s;
  }

  .chat-suggestion-pill:hover {
    background: var(--pill-hover);
    transform: scale(1.02);
    color: var(--pill-text);
  }

  .chat-suggestion-pill:active {
    transform: scale(0.98);
  }

  .cta-btn-primary {
    background: var(--color-accent);
    color: #ffffff;
  }

  .cta-btn-primary:hover {
    background: var(--color-accent-hover);
    color: #ffffff;
  }

  .pill-icon {
    font-size: 16px;
    flex-shrink: 0;
  }

  .pill-icon-svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
</style>

<script>
  const overlay = document.getElementById('chat-overlay')!;
  const toggle = document.getElementById('menubar-toggle')!;
  const popup = document.getElementById('chat-popup')!;

  function openChat() {
    overlay.classList.add('is-open');
    overlay.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-expanded', 'true');
  }

  function closeChat() {
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
  }

  toggle.addEventListener('click', (e) => {
    e.stopPropagation();
    overlay.classList.contains('is-open') ? closeChat() : openChat();
  });

  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeChat();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeChat();
  });
</script>

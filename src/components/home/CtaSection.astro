---
import { copy } from '../../content/copy';
---

<section class="cta">
  <div class="cta-inner container">
    <h2 class="cta-headline">{copy.home.cta.headline}</h2>
    <p class="cta-subheadline">{copy.home.cta.subheadline}</p>
    <div class="cta-buttons">
      <a href={copy.home.cta.primaryHref} class="cta-btn cta-btn-primary">{copy.home.cta.primaryButton}</a>
      <a href={copy.home.cta.secondaryHref} class="cta-btn cta-btn-secondary">{copy.home.cta.secondaryButton}</a>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 80px 0;
    text-align: center;
  }

  .cta-headline {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .cta-subheadline {
    font-size: 17px;
    color: var(--color-text-secondary);
    margin-bottom: 32px;
  }

  .cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    padding: 14px 28px;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition:
      background 0.15s,
      transform 0.15s;
  }

  .cta-btn:active {
    transform: scale(0.97);
  }

  .cta-btn-primary {
    background: var(--color-accent);
    color: #ffffff;
  }

  .cta-btn-primary:hover {
    background: var(--color-accent-hover);
    color: #ffffff;
  }

  .cta-btn-secondary {
    background: var(--color-border);
    color: var(--color-text);
  }

  .cta-btn-secondary:hover {
    background: var(--color-text-secondary);
    color: #ffffff;
  }
</style>
